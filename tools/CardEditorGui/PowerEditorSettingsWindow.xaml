<Window x:Class="CardEditorGui.PowerEditorSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Powers 编辑器设置"
        Height="340" Width="620"
        MinHeight="300" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="默认 Powers.cs 文件夹" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,4"
                       Text="用于「打开 Power.cs…」对话框的默认目录（建议指向仓库内 BiliBiliACGNCode\Powers）。" />
            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="浏览…" Width="80" Margin="8,0,0,0" Click="BtnBrowsePowersDir_Click" />
                <TextBox x:Name="TxtDefaultPowersDir" />
            </DockPanel>

            <TextBlock Text="powers.json 保存路径" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,4"
                       Text="用于保存 title/description/smartDescription；不存在则创建，已存在则更新键值。" />
            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="浏览…" Width="80" Margin="8,0,0,0" Click="BtnBrowsePowersJson_Click" />
                <TextBox x:Name="TxtPowersJsonPath" />
            </DockPanel>

            <TextBlock Text="能力 Key 前缀（命名空间）" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="TxtPrefix" ToolTip="例如 BILIBILIACGN（保存时自动转大写）" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="TxtSettingsPath" VerticalAlignment="Center" Margin="0,0,16,0"
                       Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis" />
            <Button Content="确定" Width="88" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click" />
            <Button Content="取消" Width="88" IsCancel="True" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>

