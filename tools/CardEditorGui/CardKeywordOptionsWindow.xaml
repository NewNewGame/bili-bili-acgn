<Window x:Class="CardEditorGui.CardKeywordOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="升级效果 — 关键字配置"
        Height="420" Width="760"
        MinHeight="320" MinWidth="520"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10"
                   Text="配置升级效果中「添加/移除关键字」下拉选项。name 为成员名（如 YYSY、Exhaust）；前缀 memberPrefix 留空则按 CustomKeyWords，可填 CardKeyword 等。保存到 settings.json（与 exe 同目录）或合并后的关键字列表。" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="88" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click" />
            <Button Content="取消" Width="88" IsCancel="True" Click="BtnCancel_Click" />
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid x:Name="GridKeywords" Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="name（成员名）" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                    <DataGridTextColumn Header="memberPrefix（空=CustomKeyWords）" Binding="{Binding MemberPrefix, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtNewKeywordName" Grid.Column="0" Margin="0,0,8,0"
                         ToolTip="成员名，如 YYSY、Exhaust" />
                <TextBox x:Name="TxtNewMemberPrefix" Grid.Column="1" Margin="0,0,8,0"
                         ToolTip="类型前缀，空=CustomKeyWords；内置关键字填 CardKeyword" />
                <TextBox x:Name="TxtNewKeywordNotes" Grid.Column="2" Margin="0,0,8,0"
                         ToolTip="备注（可选）" />
                <Button Grid.Column="3" Content="添加" Width="72" Margin="0,0,8,0" Click="BtnAddKeyword_Click" />
                <Button Grid.Column="4" Content="删除" Width="72" Click="BtnRemoveKeyword_Click" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
