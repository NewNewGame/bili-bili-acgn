<Window x:Class="CardEditorGui.BuffOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BUFF 配置"
        Height="420" Width="620"
        MinHeight="320" MinWidth="520"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10"
                   Text="配置打出效果中的 BUFF 类型下拉选项。保存到与 CardEditorGui.exe 同目录的 BuffOptions.json。" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="88" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click" />
            <Button Content="取消" Width="88" IsCancel="True" Click="BtnCancel_Click" />
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid x:Name="GridBuffs" Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="BUFF 名称（输出）" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtNewBuffName" Grid.Column="0" Margin="0,0,8,0"
                         ToolTip="新 BUFF 名称，如 StrengthPower" />
                <TextBox x:Name="TxtNewBuffNotes" Grid.Column="1" Margin="0,0,8,0"
                         ToolTip="备注（可选）" />
                <Button Grid.Column="2" Content="添加BUFF" Width="72" Margin="0,0,8,0" Click="BtnAddBuff_Click" />
                <Button Grid.Column="3" Content="删除BUFF" Width="72" Click="BtnRemoveBuff_Click" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>

