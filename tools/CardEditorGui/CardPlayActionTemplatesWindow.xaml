<Window x:Class="CardEditorGui.CardPlayActionTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理打出效果模版"
        Height="400" Width="560"
        MinHeight="280" MinWidth="440"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,10"
                   Text="模版保存在与 CardEditorGui.exe 同目录的 CardPlayActionTemplate.json。name 即操作类型（ActionType）。点「添加」将把一行打出效果追加到当前卡牌：ActionType 与模版名称一致，数值与重复次数为固定 1，其余为默认。" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="88" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click" />
            <Button Content="取消" Width="88" IsCancel="True" Click="BtnCancel_Click" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="添加" Width="88" Click="BtnAddToCard_Click" />
        </StackPanel>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Width="100" Margin="12,0,0,0">
                <Button Content="新建" Margin="0,0,0,8" Click="BtnNew_Click" />
                <Button Content="删除" Margin="0,0,0,8" Click="BtnRemove_Click" />
                <Button Content="上移" Margin="0,0,0,8" Click="BtnUp_Click" />
                <Button Content="下移" Click="BtnDown_Click" />
            </StackPanel>
            <DataGrid x:Name="GridTemplates"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="name (ActionType)" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                    <DataGridTextColumn Header="说明" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
